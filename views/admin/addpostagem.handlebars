<div class="card">
    <div class="card-body">
        <h4>Nova Postagem</h4>
        <form action="">
            <div class="mt-2">
                <label for="titulo">Título: </label>
                <input type="text" name="titulo" class="form-control">
            </div>
            <div class="mt-4">
                <label for="titulo">Slug: </label>
                <input type="text" name="slug" class="form-control">
            </div>
            <div class="mt-4">
                <label for="titulo">Descrição: </label>
                <input type="text" name="descricao" class="form-control">
            </div>
            <div class="mt-4">
                <label for="titulo">Conteúdo: </label>
                <textarea name="conteudo" class="form-control"></textarea>
            </div>
            <div class="mt-4">
                <label for="categoria">Categoria: </label>
                <select name="categoria" class="form-select">
                    <option selected>** Selecione a categoria desejada **</option>
                    {{#each categorias}}
                    <option value="{{_id}}">{{nome}}</option>
                    {{else}}
                    <option value="0">Nenhuma categoria registrada</option>
                    {{/each}}
                </select>
            </div>
            <br>
            <button class="btn btn-success">Criar Postagem</button>
        </form>
    </div>
</div>