<h2>Lista de Categorias: </h2>
<hr>
<a href="/admin/categorias/add"><button class="btn btn-primary">Nova Categoria</button></a>

{{#each categorias}}
<div class="card mt-4">
    <div class="card-body">
        <h4>{{nome}}</h4>
        <small>Slug: {{slug}}</small><br>
        <small>Data de Criação: {{date}}</small><br>
        <div class="mt-3">
            <a href="/admin/categorias/edit/{{_id}}" class="btn btn-warning">Editar</a>
            <form action="/admin/categorias/deletar" method="POST" style="display: inline;">
                <input type="hidden" name="id" value="{{_id}}">
                <button type="submit" class="btn btn-danger ms-2" onclick="return confirm("Tem certeza que deseja remover essa categoria?")">Excluir</button>
            </form>
        </div>

    </div>
</div>
{{else}}
    <h4 class="mt-4 text-secondary">Nenhuma Categoria Registada</h4>
{{/each}}